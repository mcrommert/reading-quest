# Copy to .env and fill in. Everything here is optional — with none of it set
# the bot runs with no Mattermost/Alexa/Calendar integration.

# Where the SQLite db lives (inside the container).
DB_PATH=/data/reading.db

# Season + summer window shown on the board.
CURRENT_SEASON=2026-summer
SUMMER_START=2026-06-01
SUMMER_END=2026-08-31
TZ_LOCAL=America/New_York

# Family points goal for the shared progress bar.
FAMILY_GOAL=5000

# Mattermost slash-command tokens (one per command). Leave blank to disable
# the token check (fine for a private LAN deployment).
SLASH_TOKEN_READ=
SLASH_TOKEN_READING=
SLASH_TOKEN_BOOK=
SLASH_TOKEN_BINGO=

# Alexa skill id — set to enable the /alexa endpoint (requests are rejected
# unless the incoming skill id matches).
ALEXA_SKILL_ID=

# Google Calendar sync (optional). Point CREDENTIALS_FILE at a service-account
# JSON key and CALENDAR_ID at the calendar to write to.
GCAL_CALENDAR_ID=
GCAL_CREDENTIALS_FILE=/data/gcal-credentials.json
